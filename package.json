{
  "name": "tsuzuku",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "build:packages": "npm run build --workspaces --if-present",
    "install:all": "npm install"
  }
}
